node_modules
dist
*.d.ts
!platform/frontend/src/vite-env.d.ts
*.d.ts.map
*.tsbuildinfo
.DS_Store

# Backend
platform/backend/.env
# Ignore everything inside uploads/ EXCEPT the sourcemaps subdirectory.
# Note: "uploads/" would ignore the whole directory (making exceptions impossible).
# "uploads/*" ignores its contents but allows "!uploads/sourcemaps/" exceptions to work.
platform/backend/uploads/*
!platform/backend/uploads/sourcemaps/
!platform/backend/uploads/sourcemaps/**
platform/backend/*.db
platform/backend/*.db-journal

# Frontend build
platform/frontend/dist/
platform/backend/[0-9a-f]*/
